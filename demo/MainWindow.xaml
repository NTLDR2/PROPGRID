<Window x:Class="PROPGRID_DEMO.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:prop="clr-namespace:PROPGRID;assembly=PROPGRID"
        Title="PROPGRID Demo"
        Height="600" Width="700"
        MinHeight="500" MinWidth="600" 
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">
    
    <Window.Resources>
        <!-- Data Template for CheckBoxes when Multi-Select is active -->
        <DataTemplate DataType="{x:Type sys:String}" x:Key="CheckBoxes">
            <CheckBox x:Name="chk" Margin="0,3" Content="{Binding .}" Checked="Item_Checked" Unchecked="Item_Checked" />
        </DataTemplate>
        
        <!-- Data Template for RadioButtons when Single-Select is active -->
        <DataTemplate DataType="{x:Type sys:String}" x:Key="RadioButtons">
            <RadioButton Margin="0,3" Content="{Binding .}" GroupName="radios" Checked="Item_Checked" />
        </DataTemplate>
        
        <!-- Enum values provider for Sort ComboBox -->
        <ObjectDataProvider x:Key="SortTypes" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="prop:PropertySort"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="135" />
        </Grid.ColumnDefinitions>

        <!-- Left Column: The Property Grid -->
        <Border Grid.Column="0" BorderBrush="{x:Static SystemColors.ActiveBorderBrush}" BorderThickness="1" Margin="0,0,10,0">
            <prop:WpfPropertyGrid x:Name="PropertyGrid1" 
                                  HelpVisible="{Binding ElementName=ShowDescrip, Path=IsChecked}" 
                                  ToolbarVisible="{Binding ElementName=ShowToolbar, Path=IsChecked}"
                                  PropertySort="{Binding ElementName=ComboSort, Path=SelectedItem}"
                                  SelectedPropertyChanged="PropertyGrid1_SelectedPropertyChanged" />
        </Border>

        <!-- Right Column: Settings & Selection Side Bar -->
        <StackPanel Grid.Column="1" Orientation="Vertical">
            
            <TextBlock FontWeight="Bold" Margin="0,0,0,5">Selection Type:</TextBlock>
            <RadioButton x:Name="Radio1" Margin="0,3" Content="Single Select" Click="SingleSelect_Click" />
            <RadioButton x:Name="Radio2" Margin="0,3" Content="Multi Select" Click="MultiSelect_Click" />
            <RadioButton x:Name="Radio3" Margin="0,3" Content="None" Click="NoSelection_Click" />
            
            <Separator Margin="0,10" />

            <TextBlock FontWeight="Bold" Margin="0,0,0,5">Selected Object:</TextBlock>
            <ItemsControl x:Name="ItemList" Height="110" VerticalAlignment="Top" />
            
            <Separator Margin="0,10" />

            <TextBlock FontWeight="Bold" Margin="0,0,0,5">Features:</TextBlock>
            <CheckBox x:Name="ShowDescrip" Margin="0,3" IsChecked="True" Content="Help Visible" />
            <CheckBox x:Name="ShowToolbar" Margin="0,3" IsChecked="True" Content="Toolbar Visible" />
            
            <Label Content="Sort Mode:" Margin="0,5,0,0" Padding="0" />
            <ComboBox x:Name="ComboSort" Margin="0,2,0,0" HorizontalAlignment="Stretch"
                      SelectedIndex="0" ItemsSource="{Binding Source={StaticResource SortTypes}}" />
            
            <Separator Margin="0,10" />
            <TextBlock FontWeight="Bold" Margin="0,0,0,5">Focused Property:</TextBlock>
            <TextBlock x:Name="FocusedPropertyLabel" TextWrapping="Wrap" Foreground="Gray" Text="(none)" />
        </StackPanel>
    </Grid>
</Window>
